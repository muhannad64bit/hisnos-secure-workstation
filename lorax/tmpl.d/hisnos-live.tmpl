## HisnOS Live ISO Lorax Template
## File: lorax/tmpl.d/hisnos-live.tmpl
##
## This template:
##   1. Installs the kernel and initrd into /boot/
##   2. Creates /LiveOS/rootfs.img (squashfs of the installed tree)
##   3. Copies the HisnOS 90hisnos-live dracut module into the initramfs
##   4. Generates GRUB config and isolinux config (no inst.stage2)
##   5. Sets ISO volume label to HISNOS_LIVE
##   6. Does NOT reference Anaconda stage2 anywhere
##
## Lorax template DSL reference:
##   install SRC DEST
##   installimg SQUASHFS_ARGS SRC DEST
##   runcmd COMMAND [ARGS...]
##   treeinfo SECTION KEY VALUE
##   %if CONDITION ... %end
##   %macro NAME ... %end  %NAME
##   append DEST LINE

## ── Runtime image creation ────────────────────────────────────────────────

## Create directory structure
install -d ${LIVEDIR}
install -d ${LIVEDIR}/LiveOS
install -d ${LIVEDIR}/boot
install -d ${LIVEDIR}/boot/grub
install -d ${LIVEDIR}/boot/isolinux
install -d ${LIVEDIR}/EFI/BOOT

## ── Kernel and initramfs ──────────────────────────────────────────────────

## Install the kernel image.
install ${runtime}/boot/vmlinuz* ${LIVEDIR}/boot/vmlinuz

## Install the initramfs.
## The initramfs must contain the 90hisnos-live dracut module.
## Build command (run before lorax):
##   dracut --force --add "90hisnos-live" \
##          --kver $(uname -r) \
##          /path/to/initrd.img
install ${runtime}/boot/initrd* ${LIVEDIR}/boot/initrd.img

## ── Live squashfs image ───────────────────────────────────────────────────

## Create the squashfs image at /LiveOS/rootfs.img.
## This path is hardcoded in hisnos-live-lib.sh (HISNOS_LIVE_IMG=/LiveOS/rootfs.img).
## The squashfs contains the full OS tree from ${runtime}.
##
## mksquashfs options:
##   -comp zstd      — best compression ratio with good decompress speed
##   -Xcompression-level 19  — max zstd compression
##   -noappend       — always create fresh image
##   -b 1M           — 1MiB block size for better sequential read performance
##   -e boot         — exclude /boot (kernel is installed separately above)
##   -e proc         — exclude virtual fs
##   -e sys           — exclude virtual fs
##   -e dev           — exclude virtual fs
runcmd mksquashfs ${runtime} ${LIVEDIR}/LiveOS/rootfs.img \
    -comp zstd \
    -Xcompression-level 19 \
    -noappend \
    -b 1048576 \
    -e ${runtime}/boot \
    -e ${runtime}/proc \
    -e ${runtime}/sys \
    -e ${runtime}/dev \
    -e ${runtime}/run \
    -e ${runtime}/tmp \
    -e ${runtime}/var/cache/dnf \
    -e ${runtime}/var/cache/libdnf5

## ── GRUB EFI boot ─────────────────────────────────────────────────────────

## Install GRUB EFI binary.
%if exists(${runtime}/boot/efi/EFI/fedora/grubx64.efi)
install ${runtime}/boot/efi/EFI/fedora/grubx64.efi ${LIVEDIR}/EFI/BOOT/BOOTX64.EFI
%end
%if exists(${runtime}/boot/efi/EFI/fedora/shimx64.efi)
install ${runtime}/boot/efi/EFI/fedora/shimx64.efi ${LIVEDIR}/EFI/BOOT/SHIMX64.EFI
%end

## Install GRUB modules for EFI.
%if exists(${runtime}/boot/efi/EFI/fedora/x86_64-efi)
install -r ${runtime}/boot/efi/EFI/fedora/x86_64-efi ${LIVEDIR}/EFI/BOOT/
%end

## Install Unicode font for GRUB gfxterm.
%if exists(${runtime}/usr/share/grub/unicode.pf2)
install -d ${LIVEDIR}/boot/grub/fonts
install ${runtime}/usr/share/grub/unicode.pf2 ${LIVEDIR}/boot/grub/fonts/unicode.pf2
%end

## Write GRUB config.
## NOTE: We write this inline here; the full config is also in boot/grub/grub.cfg.
## The inline version is the authoritative one embedded in the ISO.
runcmd tee ${LIVEDIR}/boot/grub/grub.cfg << 'GRUBEOF'
set default=0
set timeout=30
set timeout_style=menu
insmod all_video
insmod gfxterm
insmod png
insmod iso9660
insmod loopback
insmod linux
search --no-floppy --label --set=root HISNOS_LIVE
menuentry "HisnOS Secure Workstation — Live Session" --class hisnos {
    linux  /boot/vmlinuz hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE quiet splash rhgb selinux=0 plymouth.ignore-serial-consoles
    initrd /boot/initrd.img
}
menuentry "HisnOS Live — Safe Mode" --class hisnos {
    linux  /boot/vmlinuz hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE nomodeset xdriver=vesa selinux=0 plymouth.enable=0 loglevel=5
    initrd /boot/initrd.img
}
menuentry "HisnOS Live — Debug Mode" --class hisnos {
    linux  /boot/vmlinuz hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE rd.debug loglevel=7 selinux=0 plymouth.enable=0 systemd.log_level=debug rd.udev.debug console=tty0
    initrd /boot/initrd.img
}
menuentry "HisnOS Live — Rescue Shell (rd.break=pre-pivot)" --class hisnos {
    linux  /boot/vmlinuz hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE rd.debug loglevel=7 rd.break=pre-pivot plymouth.enable=0 console=tty0
    initrd /boot/initrd.img
}
menuentry "Install HisnOS to Disk" --class hisnos {
    linux  /boot/vmlinuz hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE hisnos.install_mode=1 quiet splash rhgb selinux=0
    initrd /boot/initrd.img
}
GRUBEOF

## Write EFI GRUB config (symlink-safe copy).
runcmd cp ${LIVEDIR}/boot/grub/grub.cfg ${LIVEDIR}/EFI/BOOT/grub.cfg

## ── ISOLINUX / SYSLINUX (BIOS boot) ──────────────────────────────────────

## Install isolinux bootloader.
%if exists(${runtime}/usr/share/syslinux/isolinux.bin)
install ${runtime}/usr/share/syslinux/isolinux.bin    ${LIVEDIR}/boot/isolinux/isolinux.bin
install ${runtime}/usr/share/syslinux/ldlinux.c32     ${LIVEDIR}/boot/isolinux/ldlinux.c32
install ${runtime}/usr/share/syslinux/vesamenu.c32    ${LIVEDIR}/boot/isolinux/vesamenu.c32
install ${runtime}/usr/share/syslinux/libcom32.c32    ${LIVEDIR}/boot/isolinux/libcom32.c32
install ${runtime}/usr/share/syslinux/libutil.c32     ${LIVEDIR}/boot/isolinux/libutil.c32
%end

## Write isolinux.cfg.
runcmd tee ${LIVEDIR}/boot/isolinux/isolinux.cfg << 'SYSEOF'
default vesamenu.c32
timeout 300
prompt 0
ui vesamenu.c32
menu title HisnOS Secure Workstation
menu color title 1;36;40 #ff6699ff #00000000 none
menu color sel   7;37;40 #ffffffff #ff333366 none

label live
  menu label HisnOS Live Session (default)
  menu default
  kernel /boot/vmlinuz
  append initrd=/boot/initrd.img hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE quiet splash selinux=0 rhgb plymouth.ignore-serial-consoles

label safe
  menu label Safe Mode (nomodeset)
  kernel /boot/vmlinuz
  append initrd=/boot/initrd.img hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE nomodeset xdriver=vesa selinux=0 plymouth.enable=0 loglevel=5

label debug
  menu label Debug Mode (verbose)
  kernel /boot/vmlinuz
  append initrd=/boot/initrd.img hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE rd.debug loglevel=7 selinux=0 plymouth.enable=0 systemd.log_level=debug console=tty0

label rescue
  menu label Rescue Shell (rd.break=pre-pivot)
  kernel /boot/vmlinuz
  append initrd=/boot/initrd.img hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE rd.debug loglevel=7 rd.break=pre-pivot plymouth.enable=0 console=tty0

label install
  menu label Install HisnOS to Disk
  kernel /boot/vmlinuz
  append initrd=/boot/initrd.img hisnos.live=1 rd.live.image root=live:CDLABEL=HISNOS_LIVE hisnos.install_mode=1 quiet splash selinux=0 rhgb
SYSEOF

## ── memtest86+ ────────────────────────────────────────────────────────────
%if exists(${runtime}/boot/memtest86+)
install ${runtime}/boot/memtest86+ ${LIVEDIR}/boot/memtest86+
%end

## ── .treeinfo metadata ────────────────────────────────────────────────────
## Used by installation tools to locate the OS.
## We deliberately do NOT add a [stage2] section (no inst.stage2 dependency).
treeinfo general  family      HisnOS
treeinfo general  version     1.0
treeinfo general  arch        x86_64
treeinfo general  packagedir  Packages
treeinfo general  repository  .
treeinfo general  timestamp   %{__import__('time').strftime('%s')}
treeinfo release  name        HisnOS Secure Workstation
treeinfo release  short       HisnOS
treeinfo release  version     1.0
treeinfo tree     build_timestamp %{__import__('time').strftime('%s')}
treeinfo tree     platforms   x86_64
treeinfo images-x86_64 boot.iso  images/boot.iso
treeinfo images-x86_64 kernel    boot/vmlinuz
treeinfo images-x86_64 initrd    boot/initrd.img

## ── ISO build instructions (comment block) ────────────────────────────────
## Build the ISO with:
##   xorriso -as mkisofs \
##     -o hisnos-live.iso \
##     -volid HISNOS_LIVE \
##     -isohybrid-mbr /usr/share/syslinux/isohdpfx.bin \
##     -eltorito-boot boot/isolinux/isolinux.bin \
##     -eltorito-catalog boot/isolinux/boot.cat \
##     -no-emul-boot \
##     -boot-load-size 4 \
##     -boot-info-table \
##     -eltorito-alt-boot \
##     -e EFI/BOOT/efiboot.img \
##     -no-emul-boot \
##     -isohybrid-gpt-basdat \
##     ${LIVEDIR}
##
## The ISO volume label HISNOS_LIVE is critical — it must match:
##   - GRUB:     search --label HISNOS_LIVE
##   - GRUB:     root=live:CDLABEL=HISNOS_LIVE
##   - isolinux: root=live:CDLABEL=HISNOS_LIVE
##   - hisnos-live-lib.sh: HISNOS_CDLABEL=HISNOS_LIVE
